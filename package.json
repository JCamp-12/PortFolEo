{
  "name": "portfolio-starter",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:nintendo-api": "npm run dev --workspace nintendo-api",
    "start:nintendo-api": "npm run start --workspace nintendo-api",
    "build": "npm run build --workspace frontend",
    "test": "npm run test --workspace backend && npm run test --workspace frontend && npm run test --workspace nintendo-api"
  }
}
